{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"💾 Remember to run /memory-update if anything significant happened this session.\"}'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(featureos-cli posts *)",
      "Bash(featureos-cli customers *)",
      "mcp__notion__notion-query-data-sources",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-search"
    ]
  }
}
